# Application
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=file:./prisma/metrico.db

# JWT (generate with: openssl rand -hex 64)
JWT_SECRET=change_me_in_production
JWT_REFRESH_SECRET=change_me_in_production_refresh

# JWT expiry
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost

# Client URL (used for OAuth redirects)
CLIENT_URL=http://localhost:5173

# File uploads
UPLOADS_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Yandex OAuth (https://oauth.yandex.ru/)
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_CALLBACK_URL=http://localhost:3000/api/auth/yandex/callback

# VK OAuth (https://vk.com/editapp?act=create)
VK_CLIENT_ID=
VK_CLIENT_SECRET=
VK_CALLBACK_URL=http://localhost:3000/api/auth/vk/callback

# Production overrides (set in .env.production or server environment)
# JWT_SECRET=<openssl rand -hex 64>
# JWT_REFRESH_SECRET=<openssl rand -hex 64>
# DATABASE_URL=file:/app/data/metrico.db
# UPLOADS_DIR=/app/data/uploads
# CORS_ORIGINS=https://metrico360.ru
# CLIENT_URL=https://metrico360.ru
# GOOGLE_CALLBACK_URL=https://metrico360.ru/api/auth/google/callback
# YANDEX_CALLBACK_URL=https://metrico360.ru/api/auth/yandex/callback
# VK_CALLBACK_URL=https://metrico360.ru/api/auth/vk/callback
